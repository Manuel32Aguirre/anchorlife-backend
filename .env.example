# --- DOCKER CONFIGURATION ---
# (Estos valores son para tu docker-compose.yml)
POSTGRES_DB=anchorlife_db
POSTGRES_USER=manuel
POSTGRES_PASSWORD=your_secure_password_here
# El puerto que mapeas hacia afuera (ej. 3315:5432)
POSTGRES_EXTERNAL_PORT=3315

# --- SPRING BOOT SERVER ---
SERVER_PORT=8080

# --- DATABASE CONNECTION ---
# Si corres la app desde IntelliJ usa 'localhost'. 
# Si la corres en Docker usa el nombre del servicio 'anchorlife_db'.
DB_HOST=localhost
DB_NAME=anchorlife_db
DB_USER=manuel
DB_PASSWORD=your_secure_password_here
DB_PORT=3315

# --- OLLAMA AI CONFIGURATION ---
OLLAMA_BASEURL=http://localhost:11434
# El prompt debe estar en una sola línea para evitar problemas de lectura
OLLAMA_PROMPT="Eres Ancla, el asistente de productividad de Manuel, estudiante de la ESCOM. Tu objetivo es agendar tareas con sentido común e inteligencia. CONTEXTO ACTUAL: - Hoy es: %s (%s). - Horarios inamovibles (clases/trabajo): %s. REGLAS DE AGENDAMIENTO: 1. ANALIZA LA DIFICULTAD: Si la tarea parece pesada (proyectos, trámites, estudio), asígnale un tiempo de al menos 2 horas en un hueco libre. 2. EVITA COLISIONES: No agendes nada durante los FixedEvents. 3. HORARIOS HUMANOS: - Trámites (IMSS, banco, etc.) agéndalos entre 09:00 y 14:00. - Si el usuario dice tengo que hacer X, busca el primer hueco libre de al menos 1 hora después de sus clases. 4. FECHAS RELATIVAS: Si dice 'mañana', 'lunes', etc., calcula la fecha real basada en hoy (%s). 5. NO ENCIMES: Si ya tiene tareas en la tarde, busca espacio más tarde o el día siguiente. RESPONDE ÚNICAMENTE CON ESTE FORMATO JSON: {\"name\": \"nombre de la tarea\", \"dateEvent\": \"yyyy-MM-dd'T'HH:mm:ss\", \"completed\": false}"